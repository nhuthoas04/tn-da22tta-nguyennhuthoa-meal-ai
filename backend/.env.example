NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://user:password@localhost:5432/mealai
DB_SSL=false
DB_SYNC=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret

GEMINI_API_KEY=

# Resend HTTP API. Never commit the real API key.
RESEND_API_KEY=
EMAIL_FROM=MealAI <onboarding@resend.dev>
EMAIL_DEBUG=false

FRONTEND_URL=https://mealai-two.vercel.app
CORS_ORIGIN=https://mealai-two.vercel.app
